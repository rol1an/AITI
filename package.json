{
  "name": "acgti",
  "private": true,
  "version": "0.2.0",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "validate:data": "node scripts/validate-character-data.mjs",
    "generate:data": "node scripts/build-character-data.mjs",
    "build": "node scripts/validate-character-data.mjs && node scripts/build-character-data.mjs && vue-tsc -b && vite build",
    "preview": "vite preview",
    "build:watch": "vite build --watch",
    "dev:pages": "wrangler pages dev dist --d1=DB --port 8788"
  },
  "dependencies": {
    "@unhead/vue": "^3.0.4",
    "html-to-image": "^1.11.13",
    "vue": "^3.5.32",
    "vue-router": "^4.6.2"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vue-tsc": "^3.2.6",
    "wrangler": "^4.83.0"
  }
}
